RewriteEngine On

# Istniejące pliki statyczne serwuj bezpośrednio
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Istniejące katalogi serwuj bezpośrednio
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# /api/* — nie przepisuj (przechodzi do Phusion Passenger → FastAPI)
RewriteRule ^api/ - [L]

# Wszystkie inne ścieżki → SPA (React Router)
RewriteRule ^ /index.html [L]
